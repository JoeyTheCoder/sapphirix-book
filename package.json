{
  "name": "sapphirix-booking",
  "private": true,
  "scripts": {
    "env:sync": "node ./scripts/sync-frontend-env.mjs",
    "db:dump": "node ./scripts/dev-db.mjs dump",
    "db:restore": "node ./scripts/dev-db.mjs restore",
    "dev:frontend": "pnpm --filter frontend start",
    "dev:backend": "pnpm --filter backend dev",
    "dev": "concurrently \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "build": "pnpm -r build"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}