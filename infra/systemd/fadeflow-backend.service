[Unit]
Description=Fadeflow backend
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/var/www/fadeflow/app/current/apps/backend
Environment=NODE_ENV=production
EnvironmentFile=/var/www/fadeflow/shared/.env
ExecStart=/usr/bin/env node dist/index.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
